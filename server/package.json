{
  "name": "@community-forum/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/ServerEntry.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/ServerEntry.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seeds/SeedDatabase.ts"
  },
  "dependencies": {
    "@community-forum/shared": "workspace:*",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/node": "^1.2.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "elysia": "^1.2.11",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
